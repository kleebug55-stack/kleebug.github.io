---
import StatusPill from "@components/StatusPill.astro";
import TagList from "@components/TagList.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { formatDate } from "@lib/content";

interface MetaItem {
  label: string;
  value?: string;
}

interface Props {
  title: string;
  description: string;
  eyebrow: string;
  date: Date;
  updated?: Date;
  status: "seedling" | "growing" | "evergreen";
  tags?: string[];
  metaItems?: MetaItem[];
}

const {
  title,
  description,
  eyebrow,
  date,
  updated,
  status,
  tags = [],
  metaItems = [],
} = Astro.props;

const visibleMetaItems = metaItems.filter((item) => item.value);
const shouldShowUpdated =
  updated && updated.toISOString().slice(0, 10) !== date.toISOString().slice(0, 10);
---

<BaseLayout title={title} description={description}>
  <article class="content-detail">
    <header class="detail-hero">
      <div class="detail-heading">
        <p class="eyebrow">{eyebrow}</p>
        <h1>{title}</h1>
        <p class="detail-summary">{description}</p>
      </div>

      {
        visibleMetaItems.length > 0 && (
          <dl class="detail-meta-grid" aria-label={`${title} 关键信息`}>
            {visibleMetaItems.map((item) => (
              <div>
                <dt>{item.label}</dt>
                <dd>{item.value}</dd>
              </div>
            ))}
          </dl>
        )
      }

      <div class="detail-meta-row">
        <span>{formatDate(date)}</span>
        {shouldShowUpdated && <span>更新于 {formatDate(updated)}</span>}
        <StatusPill status={status} />
      </div>

      <TagList tags={tags} />

      <div class="detail-actions">
        <slot name="actions" />
      </div>
    </header>

    <div class="prose detail-prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .content-detail {
    width: min(1120px, calc(100% - 32px));
    margin-inline: auto;
    padding: var(--space-12) 0 var(--space-16);
  }

  .detail-hero {
    display: grid;
    gap: var(--space-5);
    margin-bottom: var(--space-10);
  }

  .detail-heading {
    max-width: 100%;
  }

  h1 {
    max-width: 100%;
    margin: 0;
    color: var(--color-foreground);
    font-size: clamp(2.2rem, 6.2vw, 4.35rem);
    line-height: 1.04;
  }

  .detail-summary {
    max-width: 820px;
    margin: var(--space-5) 0 0;
    color: var(--color-secondary);
    font-size: clamp(1.04rem, 2.3vw, 1.2rem);
    line-height: 1.75;
  }

  .detail-meta-grid {
    display: grid;
    gap: var(--space-3);
    margin: var(--space-1) 0 0;
  }

  .detail-meta-grid div {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background:
      linear-gradient(135deg, rgb(255 252 245 / 0.9), rgb(243 236 223 / 0.68)),
      var(--color-surface);
    padding: var(--space-4);
    box-shadow: 0 10px 24px rgb(73 54 28 / 0.06);
  }

  dt {
    color: var(--color-ink-soft);
    font-size: 0.82rem;
    font-weight: 900;
  }

  dd {
    margin: 0.25rem 0 0;
    color: var(--color-primary);
    font-weight: 900;
    line-height: 1.45;
  }

  .detail-meta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-ink-soft);
    font-weight: 800;
  }

  .detail-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .detail-actions:empty {
    display: none;
  }

  .detail-prose {
    margin-inline: auto;
  }

  @media (min-width: 700px) {
    .detail-meta-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>

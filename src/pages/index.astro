---
import { getCollection } from "astro:content";
import ContentCard from "@components/ContentCard.astro";
import ProjectCard from "@components/ProjectCard.astro";
import SectionHeading from "@components/SectionHeading.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { collectionLabels, isPublished, sortByDate } from "@lib/content";

const collectionNames = ["articles", "projects", "notes", "resources", "life"] as const;

const entriesByCollection = await Promise.all(
  collectionNames.map(async (collection) => ({
    collection,
    entries: sortByDate(await getCollection(collection, isPublished)),
  })),
);

const allEntries = sortByDate(entriesByCollection.flatMap(({ entries }) => entries));
const articles = entriesByCollection.find((item) => item.collection === "articles")?.entries ?? [];
const projects = entriesByCollection.find((item) => item.collection === "projects")?.entries ?? [];
const featuredArticles = articles.filter((entry) => entry.data.featured).slice(0, 3);
const representativeProjects = (projects.some((entry) => entry.data.featured)
  ? projects.filter((entry) => entry.data.featured)
  : projects
).slice(0, 4);
const projectCount = entriesByCollection.find((item) => item.collection === "projects")?.entries.length ?? 0;
const articleCount = entriesByCollection.find((item) => item.collection === "articles")?.entries.length ?? 0;
const resourceCount = entriesByCollection.find((item) => item.collection === "resources")?.entries.length ?? 0;
const homeTiles = [
  {
    href: "/projects/",
    label: collectionLabels.projects,
    eyebrow: "PROJECTS",
    count: projectCount,
    description: "案例过程、结果复盘、后续迭代",
  },
  {
    href: "/articles/",
    label: collectionLabels.articles,
    eyebrow: "ARTICLES",
    count: articleCount,
    description: "完整表达、方法论沉淀、学习总结",
  },
  {
    href: "/resources/",
    label: collectionLabels.resources,
    eyebrow: "RESOURCES",
    count: resourceCount,
    description: "工具、书单、链接、Prompt 与案例",
  },
] as const;
const researchItems = [
  "AI 产品经理的基础素养与工作流",
  "Agent 产品的信息架构与反馈闭环",
  "把零散学习整理成可复用的数字花园",
] as const;
---

<BaseLayout>
  <section class="hero" data-reveal>
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">AI Product Digital Garden</p>
        <h1><span class="hand">Kleebug</span><span>探索 AI 与产品创新的无限可能</span></h1>
        <p class="hero-intro">
          是个有温度的AI产品数字花园，记录AI实践、技术探索与产品创新旅程
        </p>
        <div class="hero-research" aria-label="最近在研究">
          <p class="panel-label">最近在研究</p>
          <div class="research-marquee">
            <div class="research-track">
              <ul class="research-set">
                {
                  researchItems.map((item) => (
                    <li tabindex="0" aria-label={item}>
                      <span aria-hidden="true"></span>
                      {item}
                    </li>
                  ))
                }
              </ul>
              <ul class="research-set" aria-hidden="true">
                {
                  researchItems.map((item) => (
                    <li tabindex="-1">
                      <span aria-hidden="true"></span>
                      {item}
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>
      </div>
      <aside class="hero-workbench" aria-label="Kleebug 内容工作台">
        <div class="desk-shadow" aria-hidden="true"></div>
        <a class="bench-item bench-project" href="/projects/">
          <span>PROJECT</span>
          <strong>Dify 管理问答</strong>
          <small>过程 / 权限 / 反馈闭环</small>
        </a>
        <a class="bench-item bench-article" href="/articles/">
          <span>ARTICLE</span>
          <strong>AI 产品学习地图</strong>
          <small>路线 / 方法 / 复盘</small>
        </a>
        <a class="bench-item bench-resource" href="/resources/">
          <span>RESOURCE</span>
          <strong>Starter Kit</strong>
          <small>工具 / Prompt / 案例</small>
        </a>
        <div class="bench-terminal" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
          <strong>agent loop</strong>
        </div>
        <div class="bench-orbit" aria-hidden="true">
          <span>K</span>
        </div>
      </aside>
    </div>
  </section>

  <section class="container section" data-reveal>
    <SectionHeading
      eyebrow="Start here"
      title="从这几块开始逛"
      description="首页是入口地图：按项目、文章和资源组织主路径，而不是一张静态作品集。"
    />
    <div class="map-grid">
      {
        homeTiles.map((item) => (
          <a class="map-tile" href={item.href}>
            <span class="tile-eyebrow">{item.eyebrow}</span>
            <span class="tile-label">{item.label}</span>
            <strong>{item.count}</strong>
            <p>{item.description}</p>
          </a>
        ))
      }
    </div>
  </section>

  {
    featuredArticles.length > 0 && (
      <section class="container section" data-reveal>
        <SectionHeading
          eyebrow="Featured"
          title="精选文章"
          description="优先展示能说明 Kleebug 方法与学习路线的文章。"
          href="/articles/"
        />
        <div class="grid grid-3">
          {featuredArticles.map((entry) => (
            <ContentCard entry={entry} collection="articles" featured />
          ))}
        </div>
      </section>
    )
  }

  {
    representativeProjects.length > 0 && (
      <section class="container section projects-band" data-reveal>
        <SectionHeading
          eyebrow="Projects"
          title="精选项目"
          description="首页最多展示 4 个代表性项目；更多项目可以进入项目页继续查看。"
          href="/projects/"
        />
        <div class="grid grid-2">
          {representativeProjects.map((entry) => (
            <ProjectCard entry={entry} />
          ))}
        </div>
      </section>
    )
  }

  <section class="container section closing surface" data-reveal>
    <p class="eyebrow">Keep building</p>
    <h2>这里不追求一次写完，而是让内容持续变得更清楚。</h2>
    <p>
      目前已经整理了 {allEntries.length} 篇公开内容和 {resourceCount} 个资源入口。后续新增内容时，只要往
      <code>src/content</code> 放 Markdown 或 MDX，首页和列表页会自动更新。
    </p>
  </section>
</BaseLayout>

<script>
  const revealItems = document.querySelectorAll<HTMLElement>("[data-reveal]");

  if ("IntersectionObserver" in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.setAttribute("data-visible", "true");
            observer.unobserve(entry.target);
          }
        });
      },
      { rootMargin: "0px 0px -12% 0px", threshold: 0.12 },
    );

    revealItems.forEach((item) => observer.observe(item));
  } else {
    revealItems.forEach((item) => item.setAttribute("data-visible", "true"));
  }

</script>

<style>
  .hero {
    padding: var(--space-12) 0 var(--space-12);
  }

  .hero-grid {
    display: grid;
    align-items: center;
    gap: clamp(var(--space-8), 6vw, var(--space-16));
  }

  .hero-grid > * {
    min-width: 0;
  }

  .hero-copy {
    width: 100%;
    max-width: 820px;
    min-width: 0;
  }

  h1 {
    display: grid;
    gap: var(--space-2);
    max-width: 920px;
    margin: 0;
    font-size: clamp(2.45rem, 6.7vw, 5.35rem);
    line-height: 1.02;
  }

  h1 .hand {
    width: fit-content;
  }

  .hero-intro {
    max-width: 720px;
    margin: var(--space-5) 0 0;
    color: var(--color-secondary);
    font-size: clamp(1.05rem, 2.2vw, 1.35rem);
  }

  .hero-research {
    position: relative;
    width: 100%;
    max-width: min(760px, 100%);
    margin-top: var(--space-3);
    overflow: visible;
    padding: 0;
  }

  .hero-research .panel-label {
    margin-bottom: var(--space-2);
  }

  .research-marquee {
    overflow: hidden;
    margin: -0.7rem -1rem -0.9rem;
    padding: 0.7rem 1rem 0.9rem;
    mask-image: linear-gradient(90deg, transparent, #000 5%, #000 90%, transparent);
  }

  .research-track {
    display: flex;
    width: max-content;
    will-change: transform;
  }

  .research-set {
    display: flex;
    flex: 0 0 auto;
    gap: var(--space-4);
    margin: 0;
    padding: 0 var(--space-4) 0 0;
    color: var(--color-secondary);
    list-style: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .research-track {
      animation: research-marquee 24s linear infinite;
    }

    .hero-research:hover .research-track,
    .hero-research:focus-within .research-track {
      animation-play-state: paused;
    }
  }

  .hero-research li {
    position: relative;
    display: flex;
    flex: 0 0 auto;
    min-height: 48px;
    align-items: center;
    gap: var(--space-2);
    border: 1px solid rgb(36 33 27 / 0.1);
    border-radius: 999px;
    background:
      linear-gradient(135deg, rgb(var(--color-accent-rgb) / 0.12), transparent 68%),
      rgb(255 250 241 / 0.88);
    padding: 0.48rem 0.72rem 0.48rem 0.58rem;
    font-size: 0.86rem;
    font-weight: 800;
    line-height: 1;
    white-space: nowrap;
    box-shadow: 0 10px 24px rgb(73 54 28 / 0.08);
    transform-origin: center;
    transition:
      transform 360ms cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 220ms ease,
      border-color 220ms ease,
      background 220ms ease;
  }

  .hero-research li:hover,
  .hero-research li:focus,
  .hero-research li:focus-visible {
    z-index: 2;
    border-color: rgb(var(--color-accent-rgb) / 0.34);
    background:
      linear-gradient(135deg, rgb(var(--color-accent-rgb) / 0.16), transparent 68%),
      rgb(255 250 241 / 0.98);
    box-shadow: 0 16px 34px rgb(73 54 28 / 0.14);
    transform: scale(1.08);
  }

  .hero-research li span {
    display: grid;
    flex: 0 0 1.55rem;
    width: 1.55rem;
    height: 1.55rem;
    place-items: center;
    border-radius: 999px;
    background: var(--color-accent);
    color: var(--color-on-primary);
    font-size: 0.64rem;
    font-weight: 900;
  }

  .hero-research li:nth-child(1) span::before {
    content: "01";
  }

  .hero-research li:nth-child(2) span::before {
    content: "02";
  }

  .hero-research li:nth-child(3) span::before {
    content: "03";
  }

  @keyframes research-marquee {
    to {
      transform: translate3d(-50%, 0, 0);
    }
  }

  .hero-workbench {
    position: relative;
    width: 100%;
    min-height: 520px;
    min-width: 0;
    perspective: 900px;
  }

  .desk-shadow {
    position: absolute;
    inset: auto 8% 5% 6%;
    height: 46%;
    border: 1px solid rgb(36 33 27 / 0.12);
    border-radius: 34px;
    background:
      linear-gradient(135deg, rgb(255 250 241 / 0.82), rgb(234 219 196 / 0.88)),
      var(--hero-visual-background);
    box-shadow:
      0 34px 70px rgb(73 54 28 / 0.14),
      inset 0 -18px 0 rgb(36 33 27 / 0.04);
    transform: rotateX(58deg) rotateZ(-6deg);
    transform-origin: center bottom;
  }

  .bench-item,
  .bench-terminal,
  .bench-orbit {
    position: absolute;
    border: 1px solid rgb(36 33 27 / 0.12);
    box-shadow: var(--shadow-soft);
  }

  .bench-item {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 150px;
    border-radius: var(--radius-md);
    background: var(--card-background);
    padding: var(--space-5);
    text-decoration: none;
    transition:
      transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1),
      box-shadow 220ms ease,
      border-color 220ms ease;
  }

  .bench-item:hover {
    border-color: rgb(var(--color-accent-rgb) / 0.34);
    box-shadow: var(--shadow-hover);
    color: var(--color-primary);
  }

  .bench-item span {
    width: fit-content;
    border-radius: 999px;
    padding: 0.24rem 0.5rem;
    color: var(--color-primary);
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.08em;
  }

  .bench-item strong {
    margin-top: var(--space-4);
    color: var(--color-primary);
    font-size: clamp(1.2rem, 3vw, 1.65rem);
    line-height: 1.08;
  }

  .bench-item small {
    color: var(--color-secondary);
    font-weight: 800;
  }

  .bench-project {
    left: 4%;
    top: 4%;
    width: min(260px, 48%);
    background:
      linear-gradient(150deg, rgb(217 106 71 / 0.16), transparent 52%),
      var(--card-background);
    transform: rotate(-5deg);
  }

  .bench-project span {
    background: rgb(217 106 71 / 0.2);
  }

  .bench-project:hover {
    transform: translateY(-8px) rotate(-3deg);
  }

  .bench-article {
    right: 2%;
    top: 13%;
    width: min(270px, 48%);
    background:
      linear-gradient(150deg, rgb(125 179 201 / 0.2), transparent 56%),
      var(--card-background);
    transform: rotate(5deg);
  }

  .bench-article span {
    background: rgb(125 179 201 / 0.22);
  }

  .bench-article:hover {
    transform: translateY(-8px) rotate(3deg);
  }

  .bench-resource {
    left: 6%;
    bottom: 18%;
    z-index: 5;
    width: min(245px, 50%);
    background:
      linear-gradient(150deg, rgb(244 196 110 / 0.24), transparent 56%),
      var(--card-background);
    transform: rotate(2deg);
  }

  .bench-resource span {
    background: rgb(244 196 110 / 0.3);
  }

  .bench-resource:hover {
    transform: translateY(-8px) rotate(1deg);
  }

  .bench-terminal {
    right: 9%;
    bottom: 24%;
    display: grid;
    width: 190px;
    gap: 0.54rem;
    border-radius: var(--radius-md);
    background: var(--color-primary);
    color: var(--color-on-primary);
    padding: var(--space-5);
    transform: rotate(-4deg);
  }

  .bench-terminal span {
    display: block;
    height: 7px;
    border-radius: 999px;
    background: rgb(255 250 240 / 0.72);
  }

  .bench-terminal span:nth-child(2) {
    width: 74%;
    background: rgb(184 215 182 / 0.82);
  }

  .bench-terminal span:nth-child(3) {
    width: 56%;
    background: rgb(244 196 110 / 0.84);
  }

  .bench-terminal strong {
    margin-top: var(--space-3);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bench-orbit {
    left: 45%;
    top: 44%;
    display: grid;
    width: 92px;
    height: 92px;
    place-items: center;
    border-radius: 30px;
    background:
      linear-gradient(135deg, rgb(13 111 112 / 0.92), rgb(36 33 27 / 0.92)),
      var(--color-primary);
    color: var(--color-on-primary);
    font-family: var(--font-hand);
    font-size: 3rem;
    transform: translate(-50%, -50%) rotate(-8deg);
  }

  .bench-orbit::before,
  .bench-orbit::after {
    position: absolute;
    inset: -14px;
    border: 1px solid rgb(13 111 112 / 0.26);
    border-radius: 38px;
    content: "";
    transform: rotate(18deg);
  }

  .bench-orbit::after {
    inset: -28px;
    border-color: rgb(244 196 110 / 0.28);
    transform: rotate(-24deg);
  }

  .panel-label {
    margin: 0 0 var(--space-4);
    color: var(--color-accent);
    font-weight: 900;
  }

  [data-reveal] {
    opacity: 0;
    transition: opacity 320ms ease;
  }

  [data-reveal][data-visible="true"] {
    opacity: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    .bench-orbit {
      animation: float-soft 5s ease-in-out infinite alternate;
    }

    .bench-terminal {
      animation: float-soft 6s ease-in-out 500ms infinite alternate;
    }
  }

  @keyframes float-soft {
    from {
      translate: 0 0;
    }

    to {
      translate: 0 -10px;
    }
  }

  .section {
    margin-top: var(--space-16);
  }

  .map-grid {
    display: grid;
    gap: var(--space-4);
  }

  .map-tile {
    position: relative;
    min-height: 180px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--card-background);
    padding: var(--space-6);
    text-decoration: none;
    transition:
      transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1),
      box-shadow 220ms ease,
      border-color 220ms ease,
      background 220ms ease;
  }

  .map-tile::before {
    position: absolute;
    right: -28px;
    bottom: -34px;
    width: 108px;
    height: 108px;
    border-radius: 32px;
    background: rgb(var(--color-accent-rgb) / 0.1);
    content: "";
    transform: rotate(18deg);
  }

  .map-tile:hover {
    border-color: rgb(var(--color-accent-rgb) / 0.34);
    background: rgb(255 250 241 / 0.96);
    box-shadow: var(--shadow-hover);
    transform: translateY(-6px);
  }

  .tile-eyebrow {
    color: var(--color-accent);
    font-size: 0.74rem;
    font-weight: 900;
  }

  .map-tile .tile-label {
    display: block;
    margin-top: var(--space-4);
    color: var(--color-secondary);
    font-weight: 800;
  }

  .map-tile strong {
    display: block;
    margin-top: var(--space-6);
    color: var(--color-primary);
    font-size: 2.8rem;
    line-height: 1;
  }

  .map-tile p {
    margin: var(--space-4) 0 0;
    color: var(--color-secondary);
  }

  .projects-band {
    border-radius: var(--radius-lg);
    background: var(--band-background);
    padding: var(--space-8);
    box-shadow: inset 0 0 0 1px rgb(36 33 27 / 0.06);
  }

  .closing {
    padding: var(--space-8);
  }

  .closing h2 {
    max-width: 760px;
    margin: 0;
    font-size: clamp(1.8rem, 5vw, 3.4rem);
    line-height: 1.12;
  }

  .closing p:not(.eyebrow) {
    max-width: 760px;
    color: var(--color-secondary);
  }

  @media (min-width: 760px) {
    .hero-grid {
      grid-template-columns: minmax(0, 0.94fr) minmax(420px, 0.86fr);
    }

    .map-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .hero {
      padding-top: var(--space-10);
    }

    .hero-workbench {
      overflow: hidden;
      min-height: 480px;
    }

    .bench-project,
    .bench-article,
    .bench-resource,
    .bench-terminal {
      width: min(330px, 78%);
    }

    .bench-project {
      left: 0;
      top: 0;
    }

    .bench-article {
      right: 0;
      top: 118px;
    }

    .bench-resource {
      left: 3%;
      bottom: 76px;
    }

    .bench-terminal {
      right: 0;
      bottom: 30px;
      width: 170px;
    }

    .bench-orbit {
      left: 48%;
      top: 44%;
      width: 78px;
      height: 78px;
    }

    .projects-band {
      width: min(1120px, calc(100% - 32px));
      padding: var(--space-6);
    }
  }
</style>

---
import { getCollection } from "astro:content";
import ContentCard from "@components/ContentCard.astro";
import SectionHeading from "@components/SectionHeading.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { collectionLabels, isPublished, sortByDate, type AnyEntry, type SiteCollection } from "@lib/content";

const collectionNames = ["articles", "projects", "notes", "resources", "life"] as const;

const entriesByCollection = await Promise.all(
  collectionNames.map(async (collection) => ({
    collection,
    entries: sortByDate(await getCollection(collection, isPublished)),
  })),
);

const allEntries = sortByDate(
  entriesByCollection.flatMap(({ collection, entries }) =>
    entries.map((entry) => ({ ...entry, collection }) as AnyEntry & { collection: SiteCollection }),
  ),
);

const featured = allEntries.filter((entry) => entry.data.featured).slice(0, 3);
const latestArticles = entriesByCollection.find((item) => item.collection === "articles")?.entries.slice(0, 3) ?? [];
const latestNotes = entriesByCollection.find((item) => item.collection === "notes")?.entries.slice(0, 3) ?? [];
const featuredProjects = entriesByCollection.find((item) => item.collection === "projects")?.entries.slice(0, 2) ?? [];
const resourceCount = entriesByCollection.find((item) => item.collection === "resources")?.entries.length ?? 0;
const collectionDescriptions: Record<SiteCollection, string> = {
  articles: "完整表达、方法论沉淀、学习总结",
  projects: "案例过程、结果复盘、后续迭代",
  notes: "学习中、想法中、持续更新",
  resources: "工具、书单、链接、Prompt 与案例",
  life: "生活观察、个人节奏和日常温度",
};
---

<BaseLayout>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">AI Product Digital Garden</p>
        <h1><span class="hand">Kleebug</span> 是一个有个人温度的 AI 产品数字花园。</h1>
        <p class="hero-intro">
          这里沉淀方法论、项目复盘、学习路线和生活观察，记录一个产品人在 AI 时代持续生长的轨迹。
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="/projects/">看项目复盘</a>
          <a class="button button-secondary" href="/articles/">读方法文章</a>
        </div>
      </div>
      <aside class="hero-panel surface" aria-label="最近在研究">
        <p class="panel-label">最近在研究</p>
        <ul>
          <li>AI 产品经理的基础素养与工作流</li>
          <li>Agent 产品的信息架构与反馈闭环</li>
          <li>把零散学习整理成可复用的数字花园</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="container section">
    <SectionHeading
      eyebrow="Start here"
      title="从这几块开始逛"
      description="首页是入口地图：按文章、项目、笔记和资源组织内容，而不是一张静态作品集。"
    />
    <div class="map-grid">
      {
        collectionNames.slice(0, 4).map((collection) => (
          <a class="map-tile" href={`/${collection}/`}>
            <span>{collectionLabels[collection]}</span>
            <strong>{entriesByCollection.find((item) => item.collection === collection)?.entries.length ?? 0}</strong>
            <p>{collectionDescriptions[collection]}</p>
          </a>
        ))
      }
    </div>
  </section>

  {
    featured.length > 0 && (
      <section class="container section">
        <SectionHeading
          eyebrow="Featured"
          title="精选内容"
          description="优先展示能说明 Kleebug 方向的项目、文章和笔记。"
        />
        <div class="grid grid-3">
          {featured.map((entry) => (
            <ContentCard entry={entry} collection={entry.collection} featured />
          ))}
        </div>
      </section>
    )
  }

  <section class="container section split">
    <div>
      <SectionHeading eyebrow="Articles" title="最新文章" href="/articles/" />
      <div class="grid">
        {latestArticles.map((entry) => <ContentCard entry={entry} collection="articles" />)}
      </div>
    </div>
    <div>
      <SectionHeading eyebrow="Notes" title="正在生长的笔记" href="/notes/" />
      <div class="grid">
        {latestNotes.map((entry) => <ContentCard entry={entry} collection="notes" />)}
      </div>
    </div>
  </section>

  <section class="container section projects-band">
    <SectionHeading
      eyebrow="Projects"
      title="代表性项目"
      description="项目页保留过程感：问题、约束、方案、结果和下一轮迭代。"
      href="/projects/"
    />
    <div class="grid grid-2">
      {featuredProjects.map((entry) => <ContentCard entry={entry} collection="projects" featured />)}
    </div>
  </section>

  <section class="container section closing surface">
    <p class="eyebrow">Keep building</p>
    <h2>这里不追求一次写完，而是让内容持续变得更清楚。</h2>
    <p>
      目前已经整理了 {allEntries.length} 篇公开内容和 {resourceCount} 个资源入口。后续新增内容时，只要往
      <code>src/content</code> 放 Markdown 或 MDX，首页和列表页会自动更新。
    </p>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: var(--space-16) 0 var(--space-12);
  }

  .hero-grid {
    display: grid;
    align-items: end;
    gap: var(--space-8);
  }

  .hero-copy {
    max-width: 820px;
  }

  h1 {
    max-width: 900px;
    margin: 0;
    font-size: clamp(2.55rem, 8vw, 6.6rem);
    line-height: 0.98;
  }

  .hero-intro {
    max-width: 720px;
    margin: var(--space-6) 0 0;
    color: var(--color-secondary);
    font-size: clamp(1.05rem, 2.2vw, 1.35rem);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-8);
  }

  .hero-panel {
    padding: var(--space-6);
  }

  .panel-label {
    margin: 0 0 var(--space-4);
    color: var(--color-accent);
    font-weight: 900;
  }

  .hero-panel ul {
    display: grid;
    gap: var(--space-3);
    margin: 0;
    padding-left: 1.1rem;
    color: var(--color-secondary);
  }

  .section {
    margin-top: var(--space-16);
  }

  .map-grid {
    display: grid;
    gap: var(--space-4);
  }

  .map-tile {
    min-height: 180px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: rgb(255 255 255 / 0.74);
    padding: var(--space-6);
    text-decoration: none;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
  }

  .map-tile:hover {
    border-color: rgb(37 99 235 / 0.28);
    box-shadow: var(--shadow-hover);
    transform: translateY(-4px);
  }

  .map-tile span {
    color: var(--color-secondary);
    font-weight: 800;
  }

  .map-tile strong {
    display: block;
    margin-top: var(--space-6);
    color: var(--color-primary);
    font-size: 2.8rem;
    line-height: 1;
  }

  .map-tile p {
    margin: var(--space-4) 0 0;
    color: var(--color-secondary);
  }

  .split {
    display: grid;
    gap: var(--space-8);
  }

  .projects-band {
    border-radius: var(--radius-lg);
    background: rgb(246 239 231 / 0.5);
    padding: var(--space-8);
  }

  .closing {
    padding: var(--space-8);
  }

  .closing h2 {
    max-width: 760px;
    margin: 0;
    font-size: clamp(1.8rem, 5vw, 3.4rem);
    line-height: 1.12;
  }

  .closing p:not(.eyebrow) {
    max-width: 760px;
    color: var(--color-secondary);
  }

  @media (min-width: 760px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1fr) minmax(280px, 360px);
    }

    .map-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .split {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .projects-band {
      width: min(1120px, calc(100% - 32px));
      padding: var(--space-6);
    }
  }
</style>

---
import { getCollection } from "astro:content";
import ContentDetailLayout from "@layouts/ContentDetailLayout.astro";
import { isPublished } from "@lib/content";

export async function getStaticPaths() {
  const entries = await getCollection("projects", isPublished);
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const metaItems = [
  { label: "角色", value: entry.data.role },
  { label: "周期", value: entry.data.period },
  { label: "结果", value: entry.data.outcome },
];
---

<ContentDetailLayout
  title={entry.data.title}
  description={entry.data.summary}
  eyebrow="项目复盘"
  date={entry.data.date}
  updated={entry.data.updated}
  status={entry.data.status}
  tags={entry.data.tags}
  metaItems={metaItems}
>
  <Content />
</ContentDetailLayout>

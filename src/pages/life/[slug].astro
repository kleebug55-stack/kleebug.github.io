---
import { getCollection } from "astro:content";
import StatusPill from "@components/StatusPill.astro";
import TagList from "@components/TagList.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { formatDate, isPublished } from "@lib/content";

export async function getStaticPaths() {
  const entries = await getCollection("life", isPublished);
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <article class="narrow article">
    <header>
      <p class="eyebrow">生活切片</p>
      <h1>{entry.data.title}</h1>
      <p class="summary">{entry.data.summary}</p>
      <div class="meta">
        <span>{formatDate(entry.data.date)}</span>
        <StatusPill status={entry.data.status} />
      </div>
      <TagList tags={entry.data.tags} />
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .article {
    padding-top: var(--space-12);
  }

  header {
    margin-bottom: var(--space-10);
  }

  h1 {
    margin: 0;
    font-size: clamp(2.2rem, 7vw, 4.8rem);
    line-height: 1.04;
  }

  .summary {
    color: var(--color-secondary);
    font-size: 1.18rem;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    margin: var(--space-5) 0;
    color: var(--color-ink-soft);
    font-weight: 800;
  }
</style>

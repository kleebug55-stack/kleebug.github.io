---
import { getCollection } from "astro:content";
import ContentDetailLayout from "@layouts/ContentDetailLayout.astro";
import { isPublished } from "@lib/content";

export async function getStaticPaths() {
  const entries = await getCollection("notes", isPublished);
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const metaItems = [{ label: "信心", value: entry.data.confidence }];
---

<ContentDetailLayout
  title={entry.data.title}
  description={entry.data.summary}
  eyebrow="花园笔记"
  date={entry.data.date}
  updated={entry.data.updated}
  status={entry.data.status}
  tags={entry.data.tags}
  metaItems={metaItems}
>
  <Content />
</ContentDetailLayout>

<footer class="site-footer">
  <div class="container footer-inner">
    <div>
      <p class="hand footer-title">Kleebug keeps growing.</p>
      <p>把 AI 产品学习、项目实践和日常观察，整理成一个可以反复回来的地方。</p>
    </div>
    <div class="footer-contact">
      <button class="contact-trigger" type="button" aria-expanded="false" aria-controls="wechat-popover">
        联系我
      </button>
      <div class="wechat-popover" id="wechat-popover" hidden>
        <button class="popover-close" type="button" aria-label="关闭联系浮窗">×</button>
        <p class="popover-title">加微信</p>
        <img src="/wechat-qr.svg" alt="Kleebug 微信二维码" width="180" height="180" loading="lazy" />
        <p class="popover-note">扫码添加微信</p>
      </div>
      <a class="beian-link" href="http://beian.miit.gov.cn/" target="_blank" rel="noreferrer">
        粤ICP备2024331771号-1
      </a>
    </div>
  </div>
</footer>

<script>
  const footerContact = document.querySelector<HTMLElement>(".footer-contact");
  const contactTrigger = document.querySelector<HTMLButtonElement>(".contact-trigger");
  const popover = document.querySelector<HTMLElement>("#wechat-popover");
  const closeButton = document.querySelector<HTMLButtonElement>(".popover-close");

  function setPopover(open: boolean) {
    if (!contactTrigger || !popover) return;
    popover.hidden = !open;
    contactTrigger.setAttribute("aria-expanded", String(open));
  }

  contactTrigger?.addEventListener("click", () => {
    setPopover(popover?.hidden ?? true);
  });

  closeButton?.addEventListener("click", () => {
    setPopover(false);
    contactTrigger?.focus();
  });

  document.addEventListener("click", (event) => {
    if (!footerContact?.contains(event.target as Node)) {
      setPopover(false);
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      setPopover(false);
      contactTrigger?.focus();
    }
  });
</script>

<style>
  .site-footer {
    margin-top: var(--space-16);

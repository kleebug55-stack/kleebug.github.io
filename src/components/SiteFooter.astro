  }

  .footer-inner {
    display: flex;
    width: min(1200px, calc(100% - 32px));
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-8);
    margin-inline: auto;
  }

  .footer-title {
    margin: 0;
    color: var(--color-primary);
  }

  .footer-inner p {
    max-width: 620px;
    margin: 0.25rem 0 0;
  }

  .beian-link {
    display: inline-flex;
    color: var(--color-secondary);
    font-size: 0.88rem;
    font-weight: 700;
    text-decoration: none;
  }

  .beian-link:hover {
    color: var(--color-accent);
  }

  .footer-contact {
    position: relative;
    display: grid;
    justify-items: end;
    gap: 0.25rem;
    min-width: max-content;
    text-align: right;
  }

  .contact-trigger {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    border: 0;
    background: transparent;
    color: var(--color-primary);
    padding: 0;
    font: inherit;
    font-weight: 900;
    cursor: pointer;
    transition:
      color 180ms ease,
      text-decoration-color 180ms ease;
    text-decoration-line: underline;
    text-decoration-color: rgb(var(--color-accent-rgb) / 0.28);
    text-decoration-thickness: 0.12em;
    text-underline-offset: 0.28em;
  }

  .contact-trigger:hover,
  .contact-trigger[aria-expanded="true"] {
    color: var(--color-accent);
    text-decoration-color: rgb(var(--color-accent-rgb) / 0.72);
  }

  .wechat-popover {
    position: absolute;
    right: 0;
    bottom: calc(100% + 0.75rem);
    z-index: 30;
    width: min(240px, calc(100vw - 32px));
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--surface-background);
    box-shadow: var(--shadow-hover);
    padding: var(--space-5);
    text-align: center;
  }

  .wechat-popover[hidden] {
    display: none;
  }

  .popover-close {
    position: absolute;
    top: 0.55rem;
    right: 0.55rem;
    display: grid;
    width: 32px;
    height: 32px;
    place-items: center;
    border: 0;
    border-radius: 999px;
    background: rgb(23 37 29 / 0.08);
    color: var(--color-primary);
    font: inherit;
    font-size: 1.2rem;
    font-weight: 900;
    line-height: 1;
    cursor: pointer;
  }

  .popover-title {
    margin: 0 0 var(--space-3);
    color: var(--color-primary);
    font-weight: 900;
  }

  .wechat-popover img {
    display: block;
    width: 180px;
    height: 180px;
    margin-inline: auto;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: #fff;
  }

  .popover-note {
    margin: var(--space-3) 0 0;
    color: var(--color-secondary);
    font-size: 0.88rem;
    font-weight: 700;
  }

  @media (max-width: 700px) {
    .footer-inner {
      flex-direction: column;
    }

    .footer-contact {
      justify-items: start;
      min-width: 0;
      text-align: left;
    }

    .wechat-popover {
      right: auto;
      left: 0;
      bottom: calc(100% + 0.75rem);
    }
  }
</style>

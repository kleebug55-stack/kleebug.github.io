---
interface Props {
  images: string[];
}

const { images } = Astro.props;
---

<div class="gallery">
  {
    images.map((image, index) => (
      <figure>
        <img src={image} alt={`项目截图 ${index + 1}`} loading="lazy" />
      </figure>
    ))
  }
</div>

<style>
  .gallery {
    display: grid;
    gap: var(--space-4);
    margin: var(--space-8) 0;
  }

  figure {
    margin: 0;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-muted);
    aspect-ratio: 16 / 10;
  }

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (min-width: 760px) {
    .gallery {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>

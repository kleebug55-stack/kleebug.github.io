---
interface Item {
  title: string;
  text: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<ol class="timeline">
  {
    items.map((item) => (
      <li>
        <h3>{item.title}</h3>
        <p>{item.text}</p>
      </li>
    ))
  }
</ol>

<style>
  .timeline {
    display: grid;
    gap: var(--space-4);
    margin: var(--space-8) 0;
    padding: 0;
    list-style: none;
    counter-reset: timeline;
  }

  li {
    position: relative;
    counter-increment: timeline;
    display: grid;
    gap: var(--space-2);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius-sm);
    background:
      linear-gradient(135deg, rgb(var(--color-accent-rgb) / 0.08), transparent 58%),
      var(--color-surface);
    padding: var(--space-5);
    box-shadow: 0 10px 24px rgb(73 54 28 / 0.06);
  }

  li::before {
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    background: var(--color-primary);
    color: var(--color-on-primary);
    font-size: 0.82rem;
    font-weight: 900;
    line-height: 2rem;
    text-align: center;
    content: counter(timeline, decimal-leading-zero);
  }

  h3 {
    margin: 0;
    font-size: 1.05rem;
  }

  p {
    margin: 0;
  }

  @media (min-width: 760px) {
    li {
      grid-template-columns: auto minmax(0, 1fr);
      align-items: start;
    }

    p {
      grid-column: 2;
    }
  }
</style>

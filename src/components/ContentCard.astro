---
import StatusPill from "@components/StatusPill.astro";
import TagList from "@components/TagList.astro";
import { collectionLabels, entryUrl, formatDate, type AnyEntry, type SiteCollection } from "@lib/content";

interface Props {
  entry: AnyEntry;
  collection: SiteCollection;
  featured?: boolean;
}

const { entry, collection, featured = false } = Astro.props;
const href = entryUrl(collection, entry.slug);
---

<article class:list={["content-card", `collection-${collection}`, { featured }]}>
  <div class="meta">
    <span>{collectionLabels[collection]}</span>
    <span>{formatDate(entry.data.date)}</span>
  </div>
  <h3><a href={href}>{entry.data.title}</a></h3>
  <p>{entry.data.summary}</p>
  <div class="card-footer">
    <StatusPill status={entry.data.status} />
    <TagList tags={entry.data.tags.slice(0, 3)} />
  </div>
</article>

<style>
  .content-card {
    position: relative;
    display: flex;
    min-height: 240px;
    flex-direction: column;
    justify-content: space-between;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--card-background);
    box-shadow: var(--shadow-soft);
    padding: var(--space-6);
    isolation: isolate;
    overflow: hidden;
    transition:
      transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1),
      box-shadow 220ms ease,
      border-color 220ms ease;
  }

  .content-card::before {
    position: absolute;
    inset: 0 0 auto;
    z-index: -1;
    height: 8px;
    background: var(--card-accent, var(--color-accent));
    content: "";
  }

  .content-card::after {
    position: absolute;
    right: 18px;
    bottom: 18px;
    z-index: -1;
    width: 86px;
    height: 86px;
    border: 1px solid rgb(36 33 27 / 0.08);
    border-radius: 28px;
    background:
      linear-gradient(135deg, rgb(255 255 255 / 0.32), transparent),
      var(--card-accent-soft, rgb(var(--color-accent-rgb) / 0.1));
    content: "";
    opacity: 0.72;
    transform: rotate(-8deg);
  }

  .content-card:hover {
    border-color: rgb(var(--color-accent-rgb) / 0.34);
    box-shadow: var(--shadow-hover);
    transform: translateY(-6px) rotate(-0.35deg);
  }

  .collection-articles {
    --card-accent: var(--color-sky);
    --card-accent-soft: rgb(125 179 201 / 0.18);
  }

  .collection-projects {
    --card-accent: var(--color-coral);
    --card-accent-soft: rgb(217 106 71 / 0.16);
  }

  .collection-notes {
    --card-accent: var(--color-leaf);
    --card-accent-soft: rgb(184 215 182 / 0.22);
  }

  .collection-resources {
    --card-accent: var(--color-warm);
    --card-accent-soft: rgb(244 196 110 / 0.2);
  }

  .collection-life {
    --card-accent: #bda6d8;
    --card-accent-soft: rgb(189 166 216 / 0.18);
  }

  .featured {
    min-height: 300px;
    background: var(--featured-card-background);
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: var(--color-ink-soft);
    font-size: 0.83rem;
    font-weight: 900;
  }

  h3 {
    margin: var(--space-4) 0 var(--space-3);
    font-size: clamp(1.28rem, 3vw, 1.65rem);
    line-height: 1.25;
  }

  h3 a {
    color: var(--color-primary);
    text-decoration: none;
  }

  h3 a::after {
    position: absolute;
    inset: 0;
    content: "";
  }

  p {
    margin: 0 0 var(--space-6);
    color: var(--color-secondary);
  }

  .card-footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
  }

  .card-footer :global(a) {
    position: relative;
    z-index: 1;
  }
</style>

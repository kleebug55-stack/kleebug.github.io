---
import StatusPill from "@components/StatusPill.astro";
import TagList from "@components/TagList.astro";
import { entryUrl, formatDate, type AnyEntry } from "@lib/content";

interface Props {
  entry: AnyEntry;
}

const { entry } = Astro.props;
const href = entryUrl("projects", entry.slug);
const cover = entry.data.cover ?? "/project-covers/project-default.svg";
---

<article class="project-card">
  <a class="project-cover" href={href} aria-label={`查看项目：${entry.data.title}`}>
    <img src={cover} alt={`${entry.data.title} 项目封面`} loading="lazy" width="720" height="420" />
  </a>
  <div class="project-body">
    <div class="project-meta">
      <span>项目</span>
      <span>{formatDate(entry.data.date)}</span>
    </div>
    <h3><a href={href}>{entry.data.title}</a></h3>
    <p>{entry.data.summary}</p>
    <div class="project-footer">
      <StatusPill status={entry.data.status} />
      <TagList tags={entry.data.tags.slice(0, 3)} />
    </div>
  </div>
</article>

<style>
  .project-card {
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--card-background);
    box-shadow: var(--shadow-soft);
    transition:
      transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1),
      box-shadow 220ms ease,
      border-color 220ms ease;
  }

  .project-card:hover {
    border-color: rgb(var(--color-accent-rgb) / 0.34);
    box-shadow: var(--shadow-hover);
    transform: translateY(-6px);
  }

  .project-cover {
    display: block;
    aspect-ratio: 12 / 7;
    overflow: hidden;
    background: var(--color-muted);
  }

  .project-cover img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 360ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .project-card:hover .project-cover img {
    transform: scale(1.035);
  }

  .project-body {
    padding: var(--space-5);
  }

  .project-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: var(--color-ink-soft);
    font-size: 0.82rem;
    font-weight: 900;
  }

  h3 {
    margin: var(--space-3) 0 var(--space-2);
    font-size: clamp(1.22rem, 2.4vw, 1.5rem);
    line-height: 1.24;
  }

  h3 a {
    color: var(--color-primary);
    text-decoration: none;
  }

  p {
    margin: 0 0 var(--space-5);
    color: var(--color-secondary);
  }

  .project-footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
  }
</style>

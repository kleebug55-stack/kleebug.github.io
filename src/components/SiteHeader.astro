---
const navItems = [
  { href: "/projects/", label: "项目" },
  { href: "/articles/", label: "文章" },
  { href: "/resources/", label: "资源" },
  { href: "/about/", label: "关于" },
] as const;

const current = Astro.url.pathname;
---

<header class="site-header">
  <nav class="container nav" aria-label="主导航">
    <a class="brand" href="/" aria-label="Kleebug 首页">
      <span class="brand-mark" aria-hidden="true">K</span>
      <span>Kleebug</span>
    </a>
    <div class="nav-area">
      <div class="nav-links">
        {
          navItems.map((item) => (
            <a href={item.href} aria-current={current.startsWith(item.href) ? "page" : undefined}>
              {item.label}
            </a>
          ))
        }
      </div>
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0.75rem;
    z-index: 40;
    width: min(1120px, calc(100% - 24px));
    margin-inline: auto;
    border: 1px solid rgb(36 33 27 / 0.08);
    border-radius: 999px;
    background: var(--header-background);
    box-shadow: 0 14px 34px rgb(73 54 28 / 0.1);
    backdrop-filter: blur(18px);
  }

  .nav {
    display: flex;
    width: 100%;
    min-height: 60px;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    padding-inline: 0.45rem 0.6rem;
  }

  .brand {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: 0.62rem;
    border-radius: 999px;
    color: var(--color-primary);
    font-weight: 800;
    text-decoration: none;
    transition:
      background 180ms ease,
      transform 180ms ease;
  }

  .brand:hover {
    background: rgb(var(--color-accent-rgb) / 0.08);
    color: var(--color-primary);
    transform: translateY(-1px);
  }

  .brand-mark {
    display: grid;
    width: 34px;
    height: 34px;
    place-items: center;
    border: 1px solid rgb(255 250 241 / 0.4);
    border-radius: 50%;
    background: var(--color-primary);
    color: var(--color-on-primary);
    font-family: var(--font-hand);
    font-size: 1.45rem;
    line-height: 1;
    box-shadow: inset 0 -4px 0 rgb(0 0 0 / 0.12);
  }

  .nav-area {
    display: flex;
    align-items: center;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    overflow-x: auto;
    border: 1px solid rgb(36 33 27 / 0.08);
    border-radius: 999px;
    background: rgb(255 250 241 / 0.56);
    padding: 0.28rem;
  }

  .nav-links a {
    display: inline-flex;
    min-width: 76px;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0.48rem 1.2rem;
    color: var(--color-secondary);
    font-size: 0.94rem;
    font-weight: 900;
    text-decoration: none;
    white-space: nowrap;
    transition:
      background 180ms ease,
      color 180ms ease;
  }

  .nav-links a:hover,
  .nav-links a[aria-current="page"] {
    background: var(--color-primary);
    color: var(--color-primary);
    color: var(--color-on-primary);
  }

  @media (max-width: 720px) {
    .site-header {
      top: 0;
      width: 100%;
      border-top: 0;
      border-right: 0;
      border-left: 0;
      border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    }

    .nav {
      min-height: auto;
      align-items: center;
      flex-flow: row wrap;
      padding-block: 0.6rem;
    }

    .nav-area {
      display: contents;
    }

    .nav-links {
      order: 3;
      width: 100%;
      border-radius: var(--radius-md);
      justify-content: space-between;
    }

    .nav-links a {
      flex: 1;
      min-width: 0;
      padding-inline: 0.75rem;
    }
  }
</style>

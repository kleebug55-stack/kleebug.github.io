---
const navItems = [
  { href: "/articles/", label: "文章" },
  { href: "/projects/", label: "项目" },
  { href: "/notes/", label: "笔记" },
  { href: "/resources/", label: "资源" },
  { href: "/about/", label: "关于" },
];

const current = Astro.url.pathname;
---

<header class="site-header">
  <nav class="container nav" aria-label="主导航">
    <a class="brand" href="/" aria-label="Kleebug 首页">
      <span class="brand-mark" aria-hidden="true">K</span>
      <span>Kleebug</span>
    </a>
    <div class="nav-links">
      {
        navItems.map((item) => (
          <a href={item.href} aria-current={current.startsWith(item.href) ? "page" : undefined}>
            {item.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    border-bottom: 1px solid rgb(228 228 231 / 0.72);
    background: rgb(250 250 250 / 0.84);
    backdrop-filter: blur(18px);
  }

  .nav {
    display: flex;
    min-height: 68px;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: 0.7rem;
    color: var(--color-primary);
    font-weight: 800;
    text-decoration: none;
  }

  .brand-mark {
    display: grid;
    width: 34px;
    height: 34px;
    place-items: center;
    border-radius: 10px;
    background: var(--color-primary);
    color: var(--color-on-primary);
    font-family: var(--font-hand);
    font-size: 1.45rem;
    line-height: 1;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.2rem;
    overflow-x: auto;
    padding: 0.35rem 0;
  }

  .nav-links a {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    border-radius: 999px;
    padding: 0.45rem 0.72rem;
    color: var(--color-secondary);
    font-size: 0.94rem;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    transition:
      background 180ms ease,
      color 180ms ease;
  }

  .nav-links a:hover,
  .nav-links a[aria-current="page"] {
    background: var(--color-muted);
    color: var(--color-primary);
  }

  @media (max-width: 720px) {
    .nav {
      min-height: auto;
      align-items: flex-start;
      flex-direction: column;
      padding-block: 0.8rem;
    }

    .nav-links {
      width: 100%;
    }
  }
</style>
